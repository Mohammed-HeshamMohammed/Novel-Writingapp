# Copy to .env.local and set to your backend's URL to enable save/import/
# export in the editor (see backend/). Defaults to http://127.0.0.1:8000
# when unset, so this only needs to change for a non-default host/port.
VITE_API_URL=http://127.0.0.1:8000

# Supabase project (see src/shared/services/supabase.ts). Find these under
# Project Settings > API in the Supabase dashboard. The publishable key is
# safe to expose client-side. Leave unset to run without Supabase.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
